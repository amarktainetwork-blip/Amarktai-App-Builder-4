# Amarktai App Builder — environment template
# Copy to .env and fill in your values.
# NEVER commit .env with real secrets.

APP_ENV=production
JWT_SECRET=change-me-min-32-characters
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
SETTINGS_ENCRYPTION_KEY=generate-with-fernet
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MONGO_URL=mongodb://mongo:27017
DB_NAME=amarktai_app_builder
CORS_ORIGINS=https://builder.amarktai.com

# GenX — required (Amarktai model router / coding agents)
GENX_API_KEY=
GENX_BASE_URL=https://query.genx.sh/v1
GENX_MODEL_RESEARCH=
GENX_MODEL_REASONING=
GENX_MODEL_EDITS=

# Qwen — optional direct provider
# API key from https://dashscope.console.aliyun.com/
QWEN_API_KEY=
# Default base URL (international). Alternatives:
#   https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   https://dashscope.aliyuncs.com/compatible-mode/v1
#   https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Recommended models (use POST /api/qwen/apply-recommended-config to auto-fill):
QWEN_MODEL_CHAT=qwen3-max
QWEN_MODEL_CODE=qwen3-coder-plus
QWEN_MODEL_IMAGE=qwen-image-plus
QWEN_MODEL_VIDEO=qwen3-omni-flash
QWEN_MODEL_AUDIO=qwen3-asr-flash

# GitHub — optional (enables private repo import, PRs, repo creation)
GITHUB_PAT=

# Brave Search — optional (enables live web research for Scout agent)
BRAVE_SEARCH_API_KEY=

# Pixabay — optional (enables stock image/video insertion)
PIXABAY_API_KEY=

# VPS Build Storage — local workspace for GitHub repos, generated apps, and incomplete builds
# Default: /var/www/amarktai/builds
BUILDS_STORAGE_ROOT=/var/www/amarktai/builds
